    def _get_country_from_coords(self, lat: float, lon: float) -> str:
        """Определение страны по координатам через обратное геокодирование"""
        try:
            # Используем бесплатный Nominatim API (OpenStreetMap)
            url = "https://nominatim.openstreetmap.org/reverse"
            params = {
                "lat": lat,
                "lon": lon,
                "format": "json",
                "zoom": 3  # Уровень для получения страны
            }
            headers = {
                "User-Agent": "WeatherEye/1.0"
            }
            
            response = requests.get(url, params=params, headers=headers, timeout=5)
            if response.status_code == 200:
                data = response.json()
                address = data.get("address", {})
                country = address.get("country", "")
                if country:
                    return country
        except:
            pass
        return ""
Описание: Вспомогательный метод, который по координатам определяет страну через Nominatim API (OpenStreetMap). Используется для исправления случаев, когда API геокодинга возвращает неверную страну. В случае ошибки возвращает пустую строку.

